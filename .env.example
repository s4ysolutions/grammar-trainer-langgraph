# Required for Telegram bot
TELEGRAM_BOT_TOKEN=

# LLM provider: gemini | openai | huggingface | openrouter | glm | deepseek | qwen  (default: gemini)
LLM_PROVIDER=gemini
GOOGLE_API_KEY=
OPENAI_API_KEY=
# HuggingFace: uses OpenAI-compatible endpoint (langchain-openai handles it)
HUGGINGFACE_API_KEY=
# HuggingFace base URL — override for dedicated endpoints
# default: https://router.huggingface.co/hf-inference/v1
HUGGINGFACE_BASE_URL=
# OpenRouter: access many models via one API key (https://openrouter.ai)
OPENROUTER_API_KEY=
# default: https://openrouter.ai/api/v1
OPENROUTER_BASE_URL=
# ZhipuAI GLM models (glm-4-flash, glm-4-5-flash, ...)
ZHIPUAI_API_KEY=
# DeepSeek models (deepseek-chat, deepseek-reasoner, ...)
DEEPSEEK_API_KEY=
# default: https://api.deepseek.com/v1
DEEPSEEK_BASE_URL=
# Qwen models (qwen-plus, qwen-turbo, qwen-max, ...)
DASHSCOPE_API_KEY=
# default: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=

# Set to 1 to suppress noisy INFO logs from httpx and google_genai (getUpdates, AFC notices)
QUIET_LOGGERS=

# UI language: loads messages-{UI_LANG}.py if present, falls back to messages.py (Russian)
# Example: UI_LANG=en loads messages-en.py
UI_LANG=

# Seconds a provider is skipped after returning 429 (default: 300)
PROVIDER_COOLDOWN=

# Number of past exercises kept in context to avoid repetition (default: 5)
PAST_EXERCISES_LIMIT=

# Grade and generate next exercise in parallel (default: 1)
# Set to 0 to run sequentially (grade first, then generate)
PARALLEL_GENERATION=

# Optional model overrides
GENERATOR_MODEL=
GRADER_MODEL=

# Fallback providers — tried in order when primary returns 429
# Each fallback reuses its provider's existing API key (e.g. OPENROUTER_API_KEY)
# FALLBACK1_PROVIDER=openrouter
FALLBACK1_PROVIDER=
FALLBACK1_GENERATOR_MODEL=
FALLBACK1_GRADER_MODEL=

# FALLBACK2_PROVIDER=huggingface
FALLBACK2_PROVIDER=
FALLBACK2_GENERATOR_MODEL=
FALLBACK2_GRADER_MODEL=

# Webhook mode only
WEBHOOK_URL=
PORT=8443
# Secret token to verify requests come from Telegram (strongly recommended for webhook mode)
# Generate with: uv run python -m cli.gen_secret
TELEGRAM_WEBHOOK_SECRET=
